<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель администратора - Логопедический центр</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">🦋 Логопедический центр</a>
            <div class="nav-links">
                <span class="user-info">👤 <%= user.fullName %> (<%= user.role %>)</span>
                <a href="/logout" class="btn-logout">Выход</a>
            </div>
        </div>
    </nav>

    <div class="dashboard-container">
        <aside class="sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/dashboard" class="active">📊 Панель управления</a></li>
                <li><a href="/admin/users">👥 Пользователи</a></li>
                <li><a href="/admin/diary">📝 Дневник</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <h1>Панель администратора</h1>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <h3>Ученики</h3>
                    <p class="stat-number"><%= students.length %></p>
                </div>
                <div class="stat-card">
                    <h3>Учителя</h3>
                    <p class="stat-number"><%= teachers.length %></p>
                </div>
                <div class="stat-card">
                    <h3>Записей в дневнике</h3>
                    <p class="stat-number"><%= diaryEntries.length %></p>
                </div>
            </div>

            <section class="content-section">
                <h2>Быстрый доступ</h2>
                <div class="quick-actions">
                    <a href="/admin/users" class="action-card">
                        <span class="action-icon">👥</span>
                        <span>Управление пользователями</span>
                    </a>
                    <a href="/admin/diary" class="action-card">
                        <span class="action-icon">📝</span>
                        <span>Электронный дневник</span>
                    </a>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
