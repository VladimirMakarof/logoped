<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Пользователи - Администратор</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">🦋 Логопедический центр</a>
            <div class="nav-links">
                <span class="user-info">👤 <%= user.fullName %></span>
                <a href="/logout" class="btn-logout">Выход</a>
            </div>
        </div>
    </nav>

    <div class="dashboard-container">
        <aside class="sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/dashboard">📊 Панель управления</a></li>
                <li><a href="/admin/users" class="active">👥 Пользователи</a></li>
                <li><a href="/admin/diary">📝 Дневник</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <h1>Управление пользователями</h1>

            <div class="action-bar">
                <button onclick="document.getElementById('addUserModal').style.display='block'" class="btn-primary">
                    + Добавить пользователя
                </button>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>ФИО</th>
                        <th>Логин</th>
                        <th>Роль</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td><%= u.id %></td>
                            <td><%= u.fullName %></td>
                            <td><%= u.username %></td>
                            <td>
                                <span class="badge badge-<%= u.role %>">
                                    <%= u.role === 'admin' ? 'Администратор' : u.role === 'teacher' ? 'Учитель' : 'Ученик' %>
                                </span>
                            </td>
                            <td>
                                <form action="/admin/users/delete/<%= u.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Удалить пользователя?')">
                                    <button type="submit" class="btn-danger btn-sm">Удалить</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </main>
    </div>

    <!-- Модальное окно добавления -->
    <div id="addUserModal" class="modal">
        <div class="modal-content">
            <span onclick="document.getElementById('addUserModal').style.display='none'" class="close">&times;</span>
            <h2>Добавить пользователя</h2>
            <form action="/admin/users/add" method="POST">
                <div class="form-group">
                    <label>ФИО</label>
                    <input type="text" name="fullName" required>
                </div>
                <div class="form-group">
                    <label>Логин</label>
                    <input type="text" name="username" required>
                </div>
                <div class="form-group">
                    <label>Пароль</label>
                    <input type="password" name="password" required>
                </div>
                <div class="form-group">
                    <label>Роль</label>
                    <select name="role" id="roleSelect" onchange="toggleTeacherField()">
                        <option value="student">Ученик</option>
                        <option value="teacher">Учитель</option>
                        <option value="admin">Администратор</option>
                    </select>
                </div>
                <div class="form-group" id="teacherField" style="display:none;">
                    <label>Закрепить за учителем</label>
                    <select name="teacherId">
                        <% users.filter(u => u.role === 'teacher').forEach(t => { %>
                            <option value="<%= t.id %>"><%= t.fullName %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="btn-primary">Добавить</button>
            </form>
        </div>
    </div>

    <script>
        function toggleTeacherField() {
            const role = document.getElementById('roleSelect').value;
            document.getElementById('teacherField').style.display = role === 'student' ? 'block' : 'none';
        }
    </script>
</body>
</html>
