<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Дневник - Администратор</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-page">
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">🦋 Логопедический центр</a>
            <div class="nav-links">
                <span class="user-info">👤 <%= user.fullName %></span>
                <a href="/logout" class="btn-logout">Выход</a>
            </div>
        </div>
    </nav>

    <div class="dashboard-container">
        <aside class="sidebar">
            <ul class="sidebar-menu">
                <li><a href="/admin/dashboard">📊 Панель управления</a></li>
                <li><a href="/admin/users">👥 Пользователи</a></li>
                <li><a href="/admin/diary" class="active">📝 Дневник</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <h1>Электронный дневник</h1>

            <div class="action-bar">
                <button onclick="document.getElementById('addEntryModal').style.display='block'" class="btn-primary">
                    + Добавить запись
                </button>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Ученик</th>
                        <th>Тема</th>
                        <th>Домашнее задание</th>
                        <th>Оценка</th>
                        <th>Комментарий</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% entries.forEach(e => { %>
                        <tr>
                            <td><%= e.date %></td>
                            <td><%= students.find(s => s.id === e.studentId)?.fullName || 'Неизвестно' %></td>
                            <td><%= e.subject %></td>
                            <td><%= e.homework %></td>
                            <td><%= e.grade %></td>
                            <td><%= e.comment %></td>
                            <td>
                                <form action="/admin/diary/delete/<%= e.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Удалить запись?')">
                                    <button type="submit" class="btn-danger btn-sm">Удалить</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </main>
    </div>

    <!-- Модальное окно добавления -->
    <div id="addEntryModal" class="modal">
        <div class="modal-content">
            <span onclick="document.getElementById('addEntryModal').style.display='none'" class="close">&times;</span>
            <h2>Добавить запись в дневник</h2>
            <form action="/admin/diary/add" method="POST">
                <div class="form-group">
                    <label>Ученик</label>
                    <select name="studentId" required>
                        <% students.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.fullName %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Учитель</label>
                    <select name="teacherId" required>
                        <% teachers.forEach(t => { %>
                            <option value="<%= t.id %>"><%= t.fullName %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Дата</label>
                    <input type="date" name="date" required>
                </div>
                <div class="form-group">
                    <label>Тема занятия</label>
                    <input type="text" name="subject" required placeholder="Например: Постановка звука [Р]">
                </div>
                <div class="form-group">
                    <label>Домашнее задание</label>
                    <textarea name="homework" rows="3" placeholder="Упражнения для выполнения"></textarea>
                </div>
                <div class="form-group">
                    <label>Оценка</label>
                    <select name="grade">
                        <option value="5">5 - Отлично</option>
                        <option value="4">4 - Хорошо</option>
                        <option value="3">3 - Удовлетворительно</option>
                        <option value="2">2 - Неудовлетворительно</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Комментарий</label>
                    <textarea name="comment" rows="2" placeholder="Комментарий для ученика и родителей"></textarea>
                </div>
                <button type="submit" class="btn-primary">Добавить запись</button>
            </form>
        </div>
    </div>
</body>
</html>
